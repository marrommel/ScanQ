<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.firstapp">

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">
        <service
            android:name=".ClickIntentService"
            android:exported="false"></service>

        <receiver android:name=".AppWidget">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>

            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/app_widget_info" />
        </receiver>

        <activity android:name=".AppWidgetConfigureActivity">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>
        <activity
            android:name=".einstellung"
            android:label="Einstellungen"
            android:theme="@style/AppTheme" />
        <activity
            android:name=".startbildschirm"
            android:launchMode="singleTop"
            android:theme="@style/AppTheme.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>
        <activity
            android:name=".login"
            android:screenOrientation="portrait"
            android:theme="@style/AppTheme.NoActionBar" />
        <activity
            android:name=".home"
            android:screenOrientation="portrait"
            android:theme="@style/AppTheme.NoActionBar" />
        <activity
            android:name=".Haupt"
            android:theme="@style/AppTheme.SlideActivity" />
        <activity
            android:name=".quiz_menu"
            android:theme="@style/AppTheme.NoActionBar" />
        <activity
            android:name=".quiz"
            android:theme="@style/AppTheme.NoActionBar" />
        <activity
            android:name=".quiz2"
            android:theme="@style/AppTheme.NoActionBar" />
        <activity
            android:name=".quiz3"
            android:theme="@style/AppTheme.NoActionBar" />
        <activity
            android:name=".weiteres"
            android:label="weiteres"
            android:theme="@style/AppTheme.SlideActivity" />
        <activity
            android:name=".dateien"
            android:label="Dateien"
            android:theme="@style/AppTheme" />
        <activity
            android:name=".certaindata"
            android:theme="@style/AppTheme" />
        <activity
            android:name="com.theartofdev.edmodo.cropper.CropImageActivity"
            android:theme="@style/AppTheme" />
    </application>

</manifest>